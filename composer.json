{
    "name": "daycry/iban",
    "description": "IBAN library for CodeIgniter 4 (validation, parsing, formatting and entity resolution), usable standalone too.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "iban",
        "codeigniter4",
        "codeigniter",
        "validation",
        "bank",
        "sepa"
    ],
    "authors": [
        {
            "name": "Daycry",
            "email": "daycry9@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3"
    },
    "require-dev": {
        "codeigniter4/framework": "^4.6",
        "phpunit/phpunit": "^11",
        "phpstan/phpstan": "^2",
        "friendsofphp/php-cs-fixer": "^3"
    },
    "autoload": {
        "psr-4": {
            "Daycry\\Iban\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "platform": {
            "php": "8.3.20"
        },
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit",
        "analyze": "@php phpstan-analyse.php",
        "cs": "php-cs-fixer fix --dry-run --diff"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
