# Force LF line endings for text files so byte-exact checks (e.g. the registry
# drift test) are stable regardless of a checkout machine's core.autocrlf.
*.php     text eol=lf
*.csv     text eol=lf
*.json    text eol=lf
*.neon    text eol=lf
*.xml     text eol=lf
*.md      text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.dist    text eol=lf
.gitattributes text eol=lf
.gitignore     text eol=lf

# Keep the distributed package (composer archive / dist tarball) lean: exclude
# dev, CI, test and doc files that consumers don't need at runtime.
/.github            export-ignore
/tests              export-ignore
/docs               export-ignore
/bin                export-ignore
/.superpowers       export-ignore
.gitattributes      export-ignore
.gitignore          export-ignore
.php-cs-fixer.dist.php export-ignore
phpstan.neon        export-ignore
phpunit.xml         export-ignore
